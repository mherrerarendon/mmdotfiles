[core]
	excludesfile = /Users/mherrerarendon/.gitignore_global
#	pager = cat
[user]
	name = Marco Herrera-Rendon
	email = marco_herrera-rendon@comcast.com
[includeIf "gitdir:~/Developer/git/personal/"]
    path = ~/Developer/git/personal/.gitconfig
[commit]
	template = /Users/mherrerarendon/.stCommitMsg
[alias]
	unstage = reset HEAD --
	diffw = diff --ignore-space-at-eol
	showw = show --ignore-space-at-eol
	hardclean = clean -fd
	cleanpreview = clean -n
	trigger = commit --allow-empty -m "Trigger Build"
	untrack = rm -r --cached
[diff "utf16"]
    textconv = iconv -f UTF-16LE -t utf-8
[diff]
	tool = bc3
[difftool "bc3"]
    path = "/usr/local/bin/bcomp"
[merge]
	tool = bc3
[mergetool]
	bc3 = trustExitCode
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = cache --timeout=604800
[hub]
	protocol = https
[init]
	defaultBranch = main
